{
  "name": "steply-web-dashboard",
  "version": "0.2.0",
  "private": true,
  "description": "Steply React dashboard for QR session linking, movement check selection, realtime pose analysis display, recommendations, and phone-owned history sync.",
  "scripts": {
    "dev": "node scripts/prepare-mediapipe-assets.js && node scripts/dev.js",
    "server": "node server.js",
    "client": "node scripts/prepare-mediapipe-assets.js && vite --host 0.0.0.0",
    "build": "node scripts/prepare-mediapipe-assets.js && vite build",
    "start": "node server.js",
    "check": "node scripts/prepare-mediapipe-assets.js --optional && node scripts/check.js",
    "prepare:mediapipe": "node scripts/prepare-mediapipe-assets.js",
    "balance:structured:check": "node scripts/check-balance-test-state-machine.mjs",
    "chair:structured:check": "node scripts/check-chair-stand-state-machine.mjs",
    "steadi:risk:check": "node scripts/check-steadi-risk.mjs",
    "assessment:session:check": "node scripts/check-assessment-session.mjs",
    "stage2:contract:check": "node scripts/check-stage2-contract.mjs",
    "stage2:requirements:check": "node scripts/check-stage2-requirements.mjs",
    "stage2:integration:check": "node scripts/check-stage2-product-integration.mjs",
    "stage3:vulnerability:check": "node scripts/check-stage3-vulnerability.mjs",
    "stage3:catalog:check": "node scripts/check-stage3-catalog.mjs",
    "stage3:prescription:check": "node scripts/check-stage3-prescription-engine.mjs",
    "fuzzy:topsis:check": "node scripts/check-fuzzy-topsis-recommendation.mjs",
    "stage3:contract:check": "node scripts/check-stage3-contract.mjs",
    "stage3:integration:check": "node scripts/check-stage3-product-integration.mjs",
    "care:agent:check": "node scripts/check-stage4-care-agent-contract.mjs",
    "stage4:contract:check": "node scripts/check-stage4-care-agent-contract.mjs",
    "stage4:ui:check": "node scripts/check-stage4-ui-integration.mjs",
    "stage5:data-contract:check": "node scripts/check-stage5-data-contract.mjs",
    "stage5:e2e-contract": "node scripts/check-stage5-web-mobile-contract.mjs",
    "stage5:check": "npm run stage5:data-contract:check && npm run stage5:e2e-contract",
    "stage6:cleanup:check": "node scripts/prepare-mediapipe-assets.js && node scripts/check-stage6-cleanup.mjs && node scripts/check-stage6-reachability.mjs && node scripts/check-stage6-assets.mjs",
    "stage6:reachability:check": "node scripts/check-stage6-reachability.mjs",
    "stage6:assets:check": "node scripts/prepare-mediapipe-assets.js && node scripts/check-stage6-assets.mjs",
    "production:state-boundary:check": "node scripts/check-production-state-boundaries.mjs",
    "analysis:safety:check": "node scripts/check-analysis-safety-boundaries.mjs",
    "structured:pipeline:check": "node scripts/check-structured-pipeline-types.mjs",
    "pose:pipeline:check": "node scripts/check-pose-input-calibration-quality.mjs",
    "functional:findings:check": "node scripts/check-functional-findings.mjs",
    "otago:engine:check": "node scripts/check-stage3-prescription-engine.mjs",
    "ui:structured:check": "node scripts/check-ui-structured-pipeline.mjs",
    "validation:replay": "node scripts/run-landmark-replay.mjs --default-suite --output artifacts/validation/internal-validation-summary.json",
    "validation:check": "node scripts/check-internal-validation.mjs",
    "history:check": "node scripts/check-history-trends.mjs",
    "webcam:check": "node scripts/check-local-webcam.mjs",
    "camera:preview:e2e": "node scripts/check-camera-preview-e2e.mjs",
    "assessment:auto-start:check": "node scripts/check-assessment-auto-start.mjs"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.22",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.468.0",
    "qrcode": "^1.5.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "recharts": "^3.9.2",
    "vite": "^7.1.9",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "ajv": "8.20.0"
  }
}
