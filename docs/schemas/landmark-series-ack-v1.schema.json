{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://steply.local/schemas/landmark-series-ack-v1.schema.json",
  "title": "Steply landmark series persisted acknowledgement v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["type", "schemaVersion", "messageId", "profileId", "assessmentSessionId", "attemptId", "seriesId", "storedAt"],
  "properties": {
    "type": { "const": "landmark-series.ack" },
    "schemaVersion": { "const": "landmark_series.v1" },
    "messageId": { "type": "string", "minLength": 1 },
    "profileId": { "type": "string", "minLength": 1 },
    "assessmentSessionId": { "type": "string", "minLength": 1 },
    "attemptId": { "type": "string", "minLength": 1 },
    "seriesId": { "type": "string", "minLength": 1 },
    "storedAt": { "type": "integer", "minimum": 0 }
  }
}
